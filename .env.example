# NeuroDrug v4 — Environment Configuration
# Copy to .env and edit values before running

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=neurodrug_user
POSTGRES_PASSWORD=neurodrug_pass
POSTGRES_DB=neurodrug
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ac906f034fd809e5059651c54bacc619b5d5bb718944126ee33aff071ae64e2f
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MLflow ─────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_ENDPOINT=

# ── Optional Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
